# ──────────────────────────────────────────────
# SMS Core Backend — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Generate secrets: openssl rand -hex 32
# NEVER commit .env to version control.
#

# ── Application ──
NODE_ENV=development
PORT=5000

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://sms_user:your_password@localhost:5432/sms_db?schema=public

# ── Authentication (JWT) ──
# Both secrets MUST be at least 16 characters and MUST differ from each other.
JWT_SECRET=replace_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=replace_with_different_openssl_rand_hex_32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Cookie Configuration ──
# Leave COOKIE_DOMAIN empty for localhost development.
# Set to your real domain only in production with HTTPS.
COOKIE_SECRET=replace_with_openssl_rand_hex_32
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ── CORS ──
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# ── Logging ──
LOG_LEVEL=info
