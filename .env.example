# ══════════════════════════════════════════════════════════════
# School Management System — Docker Compose Environment
# ══════════════════════════════════════════════════════════════
# 1. Copy this file:  cp .env.example .env
# 2. Fill in values below (especially the secrets)
# 3. Never commit .env to version control
#
# Generate secrets with:
#   openssl rand -hex 32
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ──
# Password for the sms_user database account.
# Must match what is embedded in DATABASE_URL on the backend.
POSTGRES_PASSWORD=change_me_to_a_strong_password_min_32_chars

# ── JWT Signing Secrets ──
# MUST be at least 16 characters. MUST be different from each other.
# Compromise of one should not compromise the other.
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=change_me_different_secret_openssl_rand_hex_32

# ── Cookie Signing Secret ──
# Used by cookie-parser to cryptographically sign cookies.
COOKIE_SECRET=change_me_another_secret_openssl_rand_hex_32

# ── Cookie Configuration ──
# COOKIE_DOMAIN: Leave EMPTY for localhost. Only set for a real domain
#                e.g. COOKIE_DOMAIN=sms.school.edu.gh
#                Setting it to "localhost" breaks browsers (RFC 6265).
COOKIE_DOMAIN=

# COOKIE_SECURE: false = allow cookies over HTTP (local dev, Docker on localhost)
#                true  = require HTTPS (production only)
COOKIE_SECURE=false

# COOKIE_SAME_SITE: lax    = recommended for local dev and most production cases
#                   strict = maximum security, breaks some OAuth flows
#                   none   = required for cross-site embedding (needs Secure=true)
COOKIE_SAME_SITE=lax

# ── CORS ──
# Comma-separated list of browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000

# ── Seeding ──
# Set to true on FIRST boot to create demo accounts and sample data.
# After first boot, set back to false — re-running seed deletes all data.
RUN_SEED=false
