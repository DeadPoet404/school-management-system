# Dependencies — reinstalled fresh inside the container
node_modules/

# Next.js build output — rebuilt inside the container
.next/

# Environment files — never bake secrets into images
.env
.env.*
.env.local
.env.local.*

# Git history — not needed in image
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docs
*.md
README*
LICENSE

# Docker files themselves
Dockerfile
Dockerfile.*
docker-compose.yml
.dockerignore

# Logs
npm-debug.log*
*.log

# TypeScript incremental build cache
*.tsbuildinfo
